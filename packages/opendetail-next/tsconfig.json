{
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "test/**/*.ts",
    "test/**/*.tsx",
    "../opendetail-react/src/css-imports.d.ts"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": false,
    "ignoreDeprecations": "6.0",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "opendetail": ["../opendetail/src/index.ts"],
      "opendetail-react": ["../opendetail-react/src/index.ts"]
    },
    "types": ["node", "vitest/globals"],
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true
  }
}
