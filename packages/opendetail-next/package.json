{
  "name": "opendetail-next",
  "version": "0.8.0",
  "description": "Next.js route and link integrations for OpenDetail.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/handleui/opendetail.git",
    "directory": "packages/opendetail-next"
  },
  "homepage": "https://github.com/handleui/opendetail/tree/main/packages/opendetail-next",
  "bugs": {
    "url": "https://github.com/handleui/opendetail/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./link": {
      "types": "./dist/link.d.ts",
      "default": "./dist/link.js"
    }
  },
  "scripts": {
    "build": "./node_modules/.bin/tsup",
    "check-types": "./node_modules/.bin/tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "publint": "publint",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build && npm run check-types && npm run test && npm run publint"
  },
  "peerDependencies": {
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "opendetail": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "publint": "^0.3.18",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
