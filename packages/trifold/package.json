{
  "name": "trifold",
  "version": "0.1.0",
  "description": "Trifold: a three-panel mobile shell with swipe navigation (leading | main | trailing).",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/handleui/opendetail.git",
    "directory": "packages/trifold"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "publint": "publint",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check-types && npm run test && npm run publint"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "motion": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "motion": "^12.38.0",
    "publint": "^0.3.18",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
