{
  "name": "trifold",
  "version": "0.2.0",
  "description": "Swipe between full-width columns on phones (and larger screens): React layout primitives with touch drag, snap, and declarative jumps.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "keywords": [
    "react",
    "mobile",
    "touch",
    "swipe",
    "columns",
    "carousel",
    "panels",
    "gesture",
    "layout"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/handleui/opendetail.git",
    "directory": "packages/trifold"
  },
  "bugs": {
    "url": "https://github.com/handleui/opendetail/issues"
  },
  "homepage": "https://github.com/handleui/opendetail/tree/main/packages/trifold#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "publint": "publint",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build && npm run check-types && npm run test && npm run publint",
    "publish:dry-run": "npm publish --dry-run"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "publint": "^0.3.18",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
