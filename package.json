{
  "name": "opendetail",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "registry:build": "bunx shadcn@4.1.2 build --output apps/web/public/r",
    "changeset": "changeset",
    "changeset:status": "changeset status --verbose",
    "changeset:version": "changeset version",
    "release:version": "changeset version",
    "release:publish": "changeset publish",
    "opendetail:build": "cd packages/opendetail && bun run build",
    "opendetail:check-types": "cd packages/opendetail && bun run check-types",
    "opendetail:test": "cd packages/opendetail && bun run test",
    "opendetail:publint": "cd packages/opendetail && bun run publint",
    "opendetail-react:build": "cd packages/opendetail-react && bun run build",
    "opendetail-react:check-types": "cd packages/opendetail-react && bun run check-types",
    "opendetail-react:test": "cd packages/opendetail-react && bun run test",
    "opendetail-react:publint": "cd packages/opendetail-react && bun run publint",
    "opendetail-next:build": "cd packages/opendetail-next && bun run build",
    "opendetail-next:check-types": "cd packages/opendetail-next && bun run check-types",
    "opendetail-next:test": "cd packages/opendetail-next && bun run test",
    "opendetail-next:publint": "cd packages/opendetail-next && bun run publint",
    "opendetail-fumadocs:build": "cd packages/opendetail-fumadocs && bun run build",
    "opendetail-fumadocs:check-types": "cd packages/opendetail-fumadocs && bun run check-types",
    "opendetail-fumadocs:test": "cd packages/opendetail-fumadocs && bun run test",
    "opendetail-fumadocs:publint": "cd packages/opendetail-fumadocs && bun run publint",
    "trifold:build": "cd packages/trifold && bun run build",
    "trifold:check-types": "cd packages/trifold && bun run check-types",
    "trifold:test": "cd packages/trifold && bun run test",
    "trifold:publint": "cd packages/trifold && bun run publint",
    "release:check": "npm run opendetail:check-types && npm run opendetail:test && npm run opendetail:publint && npm run opendetail-react:check-types && npm run opendetail-react:test && npm run opendetail-react:publint && npm run opendetail-next:check-types && npm run opendetail-next:test && npm run opendetail-next:publint && npm run opendetail-fumadocs:check-types && npm run opendetail-fumadocs:test && npm run opendetail-fumadocs:publint && npm run trifold:check-types && npm run trifold:test && npm run trifold:publint",
    "release:pack": "cd packages/opendetail && npm pack && cd ../opendetail-react && npm pack && cd ../opendetail-next && npm pack && cd ../opendetail-fumadocs && npm pack && cd ../trifold && npm pack",
    "lint": "ultracite check .",
    "format": "ultracite fix .",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@changesets/cli": "^2.30.0",
    "@tailwindcss/postcss": "^4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "fumadocs-ui": "16.7.9",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "opendetail-react": "workspace:*",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "streamdown": "^2.5.0",
    "tailwindcss": "^4",
    "turbo": "^2.9.4",
    "ultracite": "7.3.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
