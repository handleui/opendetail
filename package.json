{
  "name": "opendetail",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "registry:build": "bunx shadcn@4.1.2 build --output apps/www/public/r",
    "changeset": "changeset",
    "changeset:status": "changeset status --verbose",
    "changeset:version": "changeset version",
    "opendetail:build": "cd packages/opendetail && bun run build",
    "opendetail:check-types": "cd packages/opendetail && bun run check-types",
    "opendetail:test": "cd packages/opendetail && bun run test",
    "opendetail:publint": "cd packages/opendetail && bun run publint",
    "release:check": "npm run opendetail:check-types && npm run opendetail:test && npm run opendetail:publint",
    "release:pack": "cd packages/opendetail && npm pack",
    "lint": "ultracite check .",
    "format": "ultracite fix .",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@changesets/cli": "^2.30.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "turbo": "^2.9.0",
    "tw-shimmer": "0.4.9",
    "ultracite": "7.3.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
