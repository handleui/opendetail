{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "portless opendetail next dev --webpack",
    "build": "bunx opendetail build --cwd . && next build",
    "check-types": "fumadocs-mdx && next typegen && tsc --noEmit",
    "start": "next start",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@takumi-rs/image-response": "^0.73.1",
    "fumadocs-core": "16.7.9",
    "fumadocs-mdx": "14.2.11",
    "fumadocs-ui": "16.7.9",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "next": "16.2.2",
    "opendetail": "workspace:*",
    "opendetail-fumadocs": "workspace:*",
    "opendetail-next": "workspace:*",
    "opendetail-react": "workspace:*",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shiki": "^4.0.2",
    "streamdown": "^2.5.0",
    "trifold": "workspace:*"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
